# ============================================================================
# .dockerignore - Files and directories to exclude from Docker build context
# ============================================================================

# ----------------------------------------------------------------------------
# Version control
# ----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.github
.gitlab

# ----------------------------------------------------------------------------
# IDE/Editor
# ----------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# ----------------------------------------------------------------------------
# Node.js
# ----------------------------------------------------------------------------
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store
.pnpm-debug.log

# ----------------------------------------------------------------------------
# Build outputs
# ----------------------------------------------------------------------------
.next
out
build
dist
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Test/coverage
# ----------------------------------------------------------------------------
coverage
.nyc_output
*.lcov

# ----------------------------------------------------------------------------
# Environment files (never commit these!)
# ----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Keep .env.example
!.env.example

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs
*.log
npm-debug.log*
pnpm-debug.log*

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
*.sqlite
*.db
prisma/migrations/*
!prisma/migrations/.gitkeep

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------
Dockerfile*
docker-compose*
.dockerignore

# ----------------------------------------------------------------------------
# CI/CD
# ----------------------------------------------------------------------------
.circleci
.travis.yml
.github/workflows

# ----------------------------------------------------------------------------
# Documentation (optional - exclude if you want smaller builds)
# ----------------------------------------------------------------------------
# README.md
# CHANGELOG.md
# docs/

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
.vercel
.netlify
.turbo
.eslintcache
.stylelintcache