# AgentOS Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/agentos?schema=public"

# ── Authentication ────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Encryption (for provider API keys) ────────────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# ── OAuth (optional) ──────────────────────────────────────────────────
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI Provider API Keys (optional — users provide their own) ────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GEMINI_API_KEY=""

# ── Rate Limiting (optional overrides) ────────────────────────────────
# RATE_LIMIT_AUTH_MAX=5
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=60
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_CHAT_MAX=30
# RATE_LIMIT_CHAT_WINDOW_MS=60000

# ── Docker (optional) ────────────────────────────────────────────────
# POSTGRES_USER=agentos
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=agentos
